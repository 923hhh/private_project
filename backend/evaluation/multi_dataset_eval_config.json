{
  "version": "v1.0",
  "owner": "backend/evaluation",
  "description": "多数据集评测配置：检索、问答、引用、无答案、流程指标统一编排。",
  "global": {
    "top_k_values": [1, 3, 5],
    "default_top_k": 5,
    "output_dir": "backend/evaluation/results",
    "save_raw_predictions": true,
    "timeout_seconds": 60,
    "max_dataset_size_mb": 300
  },
  "evaluation_order": [
    "techqa_retrieval",
    "dureader_retrieval",
    "squad_v2_no_answer",
    "cmrc2018_keypoint_coverage"
  ],
  "datasets": [
    {
      "id": "techqa_retrieval",
      "hf_dataset": "nvidia/TechQA-RAG-Eval",
      "task_type": "retrieval_techqa_contexts",
      "language": "en",
      "metrics": ["Recall@5", "MRR", "CitationHitRate"],
      "split": "train",
      "adapter": {
        "question_field": "question",
        "contexts_field": "contexts",
        "context_id_field": "filename",
        "context_text_field": "text"
      },
      "output_file": "backend/evaluation/results/techqa_retrieval_metrics.json"
    },
    {
      "id": "dureader_retrieval",
      "hf_dataset": "zyznull/dureader-retrieval-ranking",
      "task_type": "retrieval_dureader_ranking",
      "language": "zh",
      "metrics": ["Recall@5", "MRR", "CitationHitRate"],
      "split": "dev",
      "adapter": {
        "query_id_field": "query_id",
        "query_field": "query",
        "positive_field": "positive_passages",
        "negative_field": "negative_passages",
        "doc_id_field": "docid",
        "doc_text_field": "text"
      },
      "output_file": "backend/evaluation/results/dureader_retrieval_metrics.json"
    },
    {
      "id": "squad_v2_no_answer",
      "hf_dataset": "rajpurkar/squad_v2",
      "task_type": "qa_no_answer",
      "language": "en",
      "metrics": ["NoAnswerHallucinationRate"],
      "split": "validation",
      "adapter": {
        "question_field": "question",
        "context_field": "context",
        "answers_field": "answers",
        "is_impossible_field": "is_impossible"
      },
      "output_file": "backend/evaluation/results/squad_v2_no_answer_metrics.json"
    },
    {
      "id": "cmrc2018_keypoint_coverage",
      "hf_dataset": "hfl/cmrc2018",
      "task_type": "qa_keypoint_coverage",
      "language": "zh",
      "metrics": ["KeyPointCoverage"],
      "split": "validation",
      "adapter": {
        "question_field": "question",
        "context_field": "context",
        "answers_field": "answers",
        "extract_keypoints_by": "answer_spans"
      },
      "output_file": "backend/evaluation/results/cmrc2018_keypoint_metrics.json"
    }
  ],
  "summary": {
    "merge_outputs_to": "backend/evaluation/results/multi_dataset_summary.json",
    "headline_metrics": [
      "Recall@5",
      "MRR",
      "CitationHitRate",
      "NoAnswerHallucinationRate",
      "KeyPointCoverage"
    ]
  }
}
