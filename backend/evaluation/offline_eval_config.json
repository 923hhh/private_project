{
  "version": "v1.0",
  "description": "设备检修知识检索离线评测配置，支持正式 JSONL/CSV 测试集生成与可选 RAGAS 扩展。",
  "seed_documents_path": "backend/evaluation/softbei_knowledge_seed.json",
  "source_cases_path": "backend/evaluation/softbei_eval_cases.json",
  "output_dir": "backend/evaluation/generated",
  "dataset_prefix": "maintenance_rag",
  "sample_types": [
    "text",
    "image",
    "procedural"
  ],
  "ragas": {
    "enabled_by_default": false,
    "testset_size": 12
  },
  "runner": {
    "top_k": 5,
    "output_file": "backend/evaluation/generated/maintenance_rag_eval_report.json"
  }
}
